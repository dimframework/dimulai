# Server Configuration
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s
SERVER_SHUTDOWN_TIMEOUT=10s

# Database Configuration
DB_WRITE_HOST=localhost
DB_READ_HOSTS=localhost
DB_PORT=5432
DB_NAME=dimulai
DB_USER=postgres
DB_PASSWORD=postgres
DB_MAX_CONNS=25
DB_SSL_MODE=disable

# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-must-be-very-long
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=168h
JWT_SIGNING_METHOD=HS256
# For RS256/ES256 (optional)
# JWT_PRIVATE_KEY=/path/to/private.pem
# JWT_PUBLIC_KEYS={"kid1":"/path/to/public.pem"}
# JWT_JWKS_URL=http://...

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-CSRF-Token
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_IP=100
RATE_LIMIT_PER_USER=200
RATE_LIMIT_RESET_PERIOD=1h

# CSRF Protection
CSRF_ENABLED=true
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_TOKEN_LENGTH=32
# CSRF_EXEMPT_PATHS=/api/webhook,/public

# Email Configuration
MAIL_FROM=noreply@example.com
MAIL_TRANSPORT=null
# MAIL_TRANSPORT=smtp

# SMTP Configuration (required if MAIL_TRANSPORT=smtp)
# MAIL_SMTP_HOST=smtp.example.com
# MAIL_SMTP_PORT=587
# MAIL_SMTP_USERNAME=your-username
# MAIL_SMTP_PASSWORD=your-password

# Email Branding
MAIL_APP_NAME=Dimulai
# MAIL_LOGO_URL=https://example.com/logo.png
MAIL_PRIMARY_COLOR=#007bff
# MAIL_SUPPORT_EMAIL=support@example.com
# MAIL_SUPPORT_URL=https://example.com/help
# MAIL_COMPANY_NAME=Your Company
# MAIL_SOCIAL_LINKS=[{"name":"Twitter","url":"https://twitter.com/example"},{"name":"GitHub","url":"https://github.com/example"}]

# Application URL (required for generating password reset links)
APP_BASE_URL=http://localhost:3000
